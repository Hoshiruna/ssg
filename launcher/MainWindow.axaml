<Window
    x:Class="Gian07.Launcher.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="秋霜玉 Launcher"
    Width="540"
    Height="650"
    MinWidth="520"
    MinHeight="600"
    WindowStartupLocation="CenterScreen"
    Background="#F4F4F4"
    Foreground="#202020">

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#202020" />
    </Style>
    <Style Selector="Menu">
      <Setter Property="Background" Value="#E6E6E6" />
      <Setter Property="Foreground" Value="#202020" />
    </Style>
    <Style Selector="MenuItem">
      <Setter Property="Foreground" Value="#202020" />
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Padding" Value="12,4" />
      <Setter Property="Background" Value="#E5E5E5" />
      <Setter Property="Foreground" Value="#202020" />
      <Setter Property="BorderBrush" Value="#A8A8A8" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#202020" />
      <Setter Property="BorderBrush" Value="#9A9A9A" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#202020" />
      <Setter Property="BorderBrush" Value="#9A9A9A" />
    </Style>
    <Style Selector="GroupBox">
      <Setter Property="Padding" Value="8" />
      <Setter Property="Foreground" Value="#202020" />
    </Style>
    <Style Selector="TabItem">
      <Setter Property="Foreground" Value="#202020" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="Margin" Value="0,0,2,0" />
      <Setter Property="Background" Value="#ECECEC" />
      <Setter Property="BorderBrush" Value="#A8A8A8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              Padding="{TemplateBinding Padding}">
            <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{TemplateBinding Header}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="Background" Value="#DCD8FF" />
      <Setter Property="BorderBrush" Value="#8278D0" />
    </Style>
    <Style Selector="TabItem:pointerover">
      <Setter Property="Background" Value="#E4E4E4" />
    </Style>
    <Style Selector="RadioButton">
      <Setter Property="Foreground" Value="#202020" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#202020" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="*,Auto">
    <TabControl Grid.Row="0" Margin="8,6,8,0">
      <TabItem Header="Display">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="2,8,2,8" Spacing="14">
            <GroupBox Header="Display">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                  <TextBlock
                      VerticalAlignment="Center"
                      Text="Window Size" />
                  <ComboBox
                      x:Name="WindowSizeCombo"
                      Grid.Column="1" />
                </Grid>

                <Border Height="1" Background="#A9A9A9" />

                <StackPanel Orientation="Horizontal" Spacing="18">
                  <RadioButton
                      x:Name="FullscreenRadio"
                      Content="Fullscreen"
                      GroupName="WindowMode" />
                  <RadioButton
                      x:Name="WindowedRadio"
                      Content="Windowed"
                      GroupName="WindowMode" />
                </StackPanel>

                <CheckBox
                    x:Name="BorderlessCheck"
                    Content="Use Borderless Windowed in Fullscreen Mode" />
                <CheckBox
                    x:Name="VsyncCheck"
                    Content="Enable VSync in Exclusive Fullscreen" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Graphics">
              <StackPanel Spacing="10">
                <GroupBox Header="Color Mode">
                  <StackPanel Orientation="Horizontal" Spacing="18">
                    <RadioButton
                        x:Name="Color32Radio"
                        Content="32-bit (Recommended)"
                        GroupName="ColorMode" />
                    <RadioButton
                        x:Name="Color16Radio"
                        Content="16-bit"
                        GroupName="ColorMode" />
                  </StackPanel>
                </GroupBox>

                <GroupBox Header="Frameskip">
                  <StackPanel Orientation="Horizontal" Spacing="14">
                    <RadioButton
                        x:Name="FpsNoneRadio"
                        Content="None (Recommended)"
                        GroupName="FrameRate" />
                    <RadioButton
                        x:Name="FpsHalfRadio"
                        Content="1/2"
                        GroupName="FrameRate" />
                    <RadioButton
                        x:Name="FpsThirdRadio"
                        Content="1/3"
                        GroupName="FrameRate" />
                    <RadioButton
                        x:Name="FpsAutomaticRadio"
                        Content="Automatic"
                        GroupName="FrameRate" />
                  </StackPanel>
                </GroupBox>

              </StackPanel>
            </GroupBox>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Input">
        <Grid Margin="2,8,2,8" RowDefinitions="Auto,*">
          <GroupBox Grid.Row="0" Header="Pad Devices">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <ComboBox x:Name="ControllerCombo" />
              <Button
                  Grid.Column="1"
                  Content="Refresh Input Devices"
                  Click="RefreshControllersClick" />
            </Grid>
          </GroupBox>

          <Border
              Grid.Row="1"
              Margin="0,10,0,0"
              BorderBrush="#999999"
              BorderThickness="1">
            <Grid RowDefinitions="Auto,*">
              <Border Grid.Row="0" Background="#D9D9F5" Padding="8,5">
                <Grid ColumnDefinitions="110,*,190" ColumnSpacing="6">
                  <TextBlock Text="Action" />
                  <TextBlock Grid.Column="1" Text="Keyboard" />
                  <TextBlock Grid.Column="2" Text="Pad" />
                </Grid>
              </Border>

              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding KeyBindingRows}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border
                          BorderBrush="#B8B8B8"
                          BorderThickness="0,0,0,1"
                          Padding="6,3">
                        <Grid ColumnDefinitions="104,*,190" ColumnSpacing="6">
                          <TextBlock
                              VerticalAlignment="Center"
                              Text="{Binding Action}" />
                          <Button
                              Grid.Column="1"
                              Width="110"
                              HorizontalAlignment="Left"
                              HorizontalContentAlignment="Center"
                              Content="{Binding SelectedKey.Label}"
                              Click="RemapKeyClick" />
                          <Button
                              Grid.Column="2"
                              Width="130"
                              HorizontalAlignment="Left"
                              HorizontalContentAlignment="Center"
                              Content="{Binding SelectedPad.Label}"
                              IsEnabled="{Binding IsPadEnabled}"
                              Click="RemapPadClick" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Option">
        <StackPanel Margin="2,8,2,8" Spacing="18">
          <GroupBox Header="Game Executable Path">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox x:Name="ExecutablePathBox" />
              <Button
                  Grid.Column="1"
                  Content="Browse"
                  Click="BrowseClick" />
            </Grid>
          </GroupBox>

        </StackPanel>
      </TabItem>
    </TabControl>

    <Grid Grid.Row="1" Margin="8,8,8,10" RowDefinitions="Auto,Auto">
      <TextBlock
          x:Name="StatusText"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Foreground="#666666" />
      <StackPanel
          Grid.Row="1"
          Margin="8,0,0,0"
          HorizontalAlignment="Left"
          Orientation="Horizontal"
          Spacing="10">
        <Button
            Width="100"
            MinHeight="30"
            Padding="10,4"
            HorizontalContentAlignment="Center"
            FontSize="13"
            Content="Start Game"
            Click="StartGameClick" />
        <Button
            Width="100"
            MinHeight="30"
            Padding="10,4"
            HorizontalContentAlignment="Center"
            FontSize="13"
            Content="OK"
            Click="OkClick" />
        <Button
            Width="100"
            MinHeight="30"
            Padding="10,4"
            HorizontalContentAlignment="Center"
            FontSize="13"
            Content="Cancel"
            Click="CancelClick" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
