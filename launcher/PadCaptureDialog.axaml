<Window
    x:Class="Gian07.Launcher.PadCaptureDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Pad remap"
    Width="430"
    Height="145"
    CanResize="False"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Background="#F4F4F4"
    Foreground="#202020">

  <Grid Margin="12" RowDefinitions="*,Auto">
    <TextBlock
        x:Name="PromptText"
        VerticalAlignment="Center"
        FontSize="17"
        Text="Press any controller button or direction..." />

    <Button
        Grid.Row="1"
        Width="90"
        MinHeight="28"
        HorizontalAlignment="Center"
        HorizontalContentAlignment="Center"
        Content="Cancel"
        Click="CancelClick" />
  </Grid>
</Window>
