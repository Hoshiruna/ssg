#pragma code_page(65001)

#include <windows.h>
#include <commctrl.h>
#include "resource.h"

IDI_LAUNCHER ICON "art\\sh01.ico"

IDR_MAIN_MENU MENU
BEGIN
    POPUP "Menu"
    BEGIN
        MENUITEM "Save and Exit",       IDM_SAVE_EXIT
        MENUITEM "Exit without Saving", IDM_EXIT
        MENUITEM SEPARATOR
        MENUITEM "Start Game",          IDM_START_GAME
    END
END

IDD_MAIN DIALOGEX 0, 0, 320, 390
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX
CAPTION "秋霜玉 Launcher"
MENU IDR_MAIN_MENU
FONT 9, "Segoe UI"
BEGIN
    CONTROL         "", IDC_MAIN_TAB, WC_TABCONTROL, WS_TABSTOP | TCS_FOCUSNEVER, 5, 5, 310, 346
    PUSHBUTTON      "Save and Exit", IDC_SAVE_EXIT, 5, 360, 82, 22
    PUSHBUTTON      "Exit without Saving", IDC_EXIT, 92, 360, 82, 22
    DEFPUSHBUTTON   "Start Game", IDC_START_GAME, 179, 360, 82, 22
END

IDD_DISPLAY DIALOGEX 0, 0, 300, 322
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI"
BEGIN
    GROUPBOX        "Display", -1, 4, 3, 292, 95
    LTEXT           "Window Size", -1, 10, 16, 62, 10
    COMBOBOX        IDC_WINDOW_SIZE, 10, 29, 166, 100, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
    AUTORADIOBUTTON "Fullscreen", IDC_FULLSCREEN, 10, 51, 66, 12, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "Windowed", IDC_WINDOWED, 82, 51, 62, 12
    AUTOCHECKBOX    "Use Borderless Windowed in Fullscreen Mode", IDC_BORDERLESS, 10, 68, 238, 12, WS_TABSTOP
    AUTOCHECKBOX    "Render game geometry at the selected size", IDC_SCALE_GEOMETRY, 10, 84, 224, 12, WS_TABSTOP

    GROUPBOX        "Graphics", -1, 4, 105, 292, 143
    GROUPBOX        "Rendering API", -1, 10, 116, 280, 39
    COMBOBOX        IDC_GRAPHICS_API, 16, 131, 166, 100, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP

    GROUPBOX        "Color Mode", -1, 10, 160, 280, 35
    AUTORADIOBUTTON "32-bit (Recommended)", IDC_BPP_32, 16, 175, 105, 12, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "16-bit", IDC_BPP_16, 126, 175, 50, 12
    AUTORADIOBUTTON "8-bit (Legacy)", IDC_BPP_8, 181, 175, 75, 12

    GROUPBOX        "Frameskip", -1, 10, 200, 280, 40
    AUTORADIOBUTTON "None (Recommended)", IDC_FPS_NONE, 16, 216, 102, 12, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "1/2", IDC_FPS_HALF, 121, 216, 38, 12
    AUTORADIOBUTTON "1/3", IDC_FPS_THIRD, 164, 216, 38, 12
    AUTORADIOBUTTON "Unlimited", IDC_FPS_UNLIMITED, 207, 216, 61, 12
END

IDD_INPUT DIALOGEX 0, 0, 300, 322
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI"
BEGIN
    GROUPBOX        "Pad Devices", -1, 4, 3, 292, 43
    COMBOBOX        IDC_PAD_DEVICES, 10, 18, 202, 100, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Refresh Input Devices", IDC_REFRESH_DEVICES, 216, 17, 74, 16

    CONTROL         "", IDC_INPUT_SUBTAB, WC_TABCONTROL, WS_TABSTOP | TCS_FOCUSNEVER, 4, 51, 292, 267

    LTEXT           "Action", IDC_KEY_HEADER_ACTION, 9, 75, 58, 14, SS_SUNKEN
    LTEXT           "Keyboard", IDC_KEY_HEADER_KEYBOARD, 68, 75, 103, 14, SS_SUNKEN
    LTEXT           "Pad", IDC_KEY_HEADER_PAD, 172, 75, 116, 14, SS_SUNKEN

    LTEXT           "Left", IDC_ACTION_LEFT, 9, 91, 58, 17, SS_SUNKEN
    EDITTEXT        IDC_KEY_LEFT, 70, 92, 99, 15, ES_CENTER | ES_READONLY
    EDITTEXT        IDC_PAD_LEFT, 174, 92, 112, 15, ES_CENTER | ES_READONLY

    LTEXT           "Right", IDC_ACTION_RIGHT, 9, 110, 58, 17, SS_SUNKEN
    EDITTEXT        IDC_KEY_RIGHT, 70, 111, 99, 15, ES_CENTER | ES_READONLY
    EDITTEXT        IDC_PAD_RIGHT, 174, 111, 112, 15, ES_CENTER | ES_READONLY

    LTEXT           "Up", IDC_ACTION_UP, 9, 129, 58, 17, SS_SUNKEN
    EDITTEXT        IDC_KEY_UP, 70, 130, 99, 15, ES_CENTER | ES_READONLY
    EDITTEXT        IDC_PAD_UP, 174, 130, 112, 15, ES_CENTER | ES_READONLY

    LTEXT           "Down", IDC_ACTION_DOWN, 9, 148, 58, 17, SS_SUNKEN
    EDITTEXT        IDC_KEY_DOWN, 70, 149, 99, 15, ES_CENTER | ES_READONLY
    EDITTEXT        IDC_PAD_DOWN, 174, 149, 112, 15, ES_CENTER | ES_READONLY

    LTEXT           "Shot / Accept", IDC_ACTION_SHOT, 9, 167, 58, 17, SS_SUNKEN
    EDITTEXT        IDC_KEY_SHOT, 70, 168, 99, 15, ES_CENTER | ES_READONLY
    COMBOBOX        IDC_PAD_SHOT, 174, 168, 112, 160, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Bomb", IDC_ACTION_BOMB, 9, 186, 58, 17, SS_SUNKEN
    EDITTEXT        IDC_KEY_BOMB, 70, 187, 99, 15, ES_CENTER | ES_READONLY
    COMBOBOX        IDC_PAD_BOMB, 174, 187, 112, 160, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Focus", IDC_ACTION_FOCUS, 9, 205, 58, 17, SS_SUNKEN
    EDITTEXT        IDC_KEY_FOCUS, 70, 206, 99, 15, ES_CENTER | ES_READONLY
    COMBOBOX        IDC_PAD_FOCUS, 174, 206, 112, 160, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Cancel / Pause", IDC_ACTION_CANCEL, 9, 224, 58, 17, SS_SUNKEN
    EDITTEXT        IDC_KEY_CANCEL, 70, 225, 99, 15, ES_CENTER | ES_READONLY
    COMBOBOX        IDC_PAD_CANCEL, 174, 225, 112, 160, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Connected controllers detected through the Windows joystick API:", IDC_DEVICE_HELP, 10, 78, 274, 18
    LISTBOX         IDC_DEVICE_LIST, 10, 99, 274, 115, LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Select a pad device above to view its capabilities.", IDC_DEVICE_DETAILS, 10, 220, 274, 42

    LTEXT           "Move the selected controller axes and press buttons to test its current input.", IDC_TEST_HELP, 10, 78, 274, 22
    LTEXT           "X Axis: —", IDC_TEST_X, 15, 112, 260, 16
    LTEXT           "Y Axis: —", IDC_TEST_Y, 15, 136, 260, 16
    LTEXT           "Buttons: None", IDC_TEST_BUTTONS, 15, 160, 260, 72
END

IDD_OPTION DIALOGEX 0, 0, 300, 322
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI"
BEGIN
    GROUPBOX        "Game Executable Path", -1, 4, 3, 292, 43
    EDITTEXT        IDC_GAME_PATH, 10, 18, 230, 15, ES_AUTOHSCROLL | WS_TABSTOP
    PUSHBUTTON      "Browse", IDC_BROWSE_GAME, 245, 17, 45, 16

    GROUPBOX        "Options", -1, 4, 55, 292, 145
    AUTOCHECKBOX    "Enable background music", IDC_ENABLE_BGM, 10, 70, 170, 12, WS_TABSTOP
    AUTOCHECKBOX    "Enable sound effects", IDC_ENABLE_SE, 10, 87, 170, 12, WS_TABSTOP
    AUTOCHECKBOX    "Normalize background music volume", IDC_NORMALIZE_BGM, 10, 104, 205, 12, WS_TABSTOP
    AUTOCHECKBOX    "Enable gamepad input", IDC_ENABLE_GAMEPAD, 10, 121, 170, 12, WS_TABSTOP
    AUTOCHECKBOX    "Allow Z / Shot to advance messages", IDC_Z_MESSAGE_SKIP, 10, 138, 205, 12, WS_TABSTOP
    AUTOCHECKBOX    "Hold Z / Shot for focus movement", IDC_Z_FOCUS, 10, 155, 205, 12, WS_TABSTOP
    LTEXT           "Screenshot format", -1, 10, 177, 80, 10
    COMBOBOX        IDC_SCREENSHOT_FORMAT, 94, 174, 154, 120, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
END
